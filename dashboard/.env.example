# ───────────────────────────────────────────────────────────
# Dashboard Dearmas Costantini · variables de entorno
# Copy this file to `.env.local` and fill the values.
# `.env.local` is gitignored — never commit secrets.
#
# Para verificar qué tenés cargado en Vercel: GET /api/diag/env
# ───────────────────────────────────────────────────────────

# === Supabase (obligatorio) ===
# Settings → API en el dashboard de Supabase.
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Server-only. Bypassa RLS — NUNCA con prefijo NEXT_PUBLIC_.
# Settings → API → "Reveal" en service_role secret.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# === Anthropic (obligatorio para consultor + phase reports) ===
# console.anthropic.com → API Keys.
ANTHROPIC_API_KEY=sk-ant-...

# === GitHub Actions dispatch (obligatorio para agentes IA) ===
# Sin estas tres vars el dashboard no puede disparar Content Creator,
# Stock, Logistics, Analytics, etc.
# Token: GitHub → Settings → Developer settings → Personal access tokens →
# Fine-grained tokens → permiso "Actions: Read+Write" sobre el repo.
GH_DISPATCH_TOKEN=github_pat_...
GITHUB_OWNER=giancostantini
GITHUB_REPO=dc-scale-agents

# === Calendly (opcional · solo si Calendly Pro está activo) ===
# Webhook → "Signing key" en la config del webhook.
CALENDLY_WEBHOOK_SECRET=
